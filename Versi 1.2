        // --- KONFIGURASI LEVEL KOORDINAT MAP (12x12 GRID) ---
        function getLevelCoords(level) {
            if (level === 1) {
                return [
                    {r:11, c:0}, {r:11, c:1}, {r:11, c:2}, {r:10, c:2}, {r:9, c:2}, {r:8, c:2}, {r:8, c:1}, {r:7, c:1}, {r:6, c:1}, {r:5, c:1}, {r:4, c:1}, {r:3, c:1}, {r:2, c:1}, {r:2, c:2}, {r:2, c:3}, {r:3, c:3}, {r:4, c:3}, {r:5, c:3}, {r:6, c:3}, {r:7, c:3}, {r:8, c:3}, {r:9, c:3}, {r:10, c:3}, {r:10, c:4}, {r:10, c:5}, {r:9, c:5}, {r:8, c:5}, {r:7, c:5}, {r:6, c:5}, {r:5, c:5}, {r:4, c:5}, {r:3, c:5}, {r:2, c:5}, {r:1, c:5}, {r:0, c:5}, {r:0, c:6}, {r:0, c:7}, {r:1, c:7}, {r:2, c:7}, {r:3, c:7}, {r:4, c:7}, {r:5, c:7}, {r:6, c:7}, {r:7, c:7}, {r:8, c:7}, {r:9, c:7}, {r:10, c:7}, {r:11, c:7}, {r:11, c:8}, {r:11, c:9}, {r:10, c:9}, {r:9, c:9}, {r:8, c:9}, {r:8, c:10}, {r:8, c:11}, {r:9, c:11}, {r:10, c:11}, {r:11, c:11}
                ];
            } else if (level === 2) {
                // S-Curve Horizontal Zigzag yang berliku-liku dramatis
                let path = [];
                for(let c=0; c<=9; c++) path.push({r:11, c});
                path.push({r:10, c:9});
                for(let c=9; c>=1; c--) path.push({r:9, c});
                path.push({r:8, c:1});
                for(let c=1; c<=9; c++) path.push({r:7, c});
                path.push({r:6, c:9});
                for(let c=9; c>=1; c--) path.push({r:5, c});
                path.push({r:4, c:1});
                for(let c=1; c<=9; c++) path.push({r:3, c});
                path.push({r:2, c:9});
                for(let c=9; c>=1; c--) path.push({r:1, c});
                path.push({r:0, c:1});
                for(let c=2; c<=11; c++) path.push({r:0, c});
                return path;
            } else {
                // Grand Castle Spiral (Melingkar melingkar dari luar ke pusat terdalam)
                return [
                    {r:11, c:0}, {r:11, c:1}, {r:11, c:2}, {r:11, c:3}, {r:11, c:4}, {r:11, c:5}, {r:11, c:6}, {r:11, c:7}, {r:11, c:8}, {r:11, c:9}, {r:11, c:10}, {r:11, c:11},
                    {r:10, c:11}, {r:9, c:11}, {r:8, c:11}, {r:7, c:11}, {r:6, c:11}, {r:5, c:11}, {r:4, c:11}, {r:3, c:11}, {r:2, c:11}, {r:1, c:11}, {r:0, c:11},
                    {r:0, c:10}, {r:0, c:9}, {r:0, c:8}, {r:0, c:7}, {r:0, c:6}, {r:0, c:5}, {r:0, c:4}, {r:0, c:3}, {r:0, c:2}, {r:0, c:1}, {r:0, c:0},
                    {r:1, c:0}, {r:2, c:0}, {r:3, c:0}, {r:4, c:0}, {r:5, c:0}, {r:6, c:0}, {r:7, c:0}, {r:8, c:0}, {r:9, c:0},
                    {r:9, c:1}, {r:9, c:2}, {r:9, c:3}, {r:9, c:4}, {r:9, c:5}, {r:9, c:6}, {r:9, c:7}, {r:9, c:8}, {r:9, c:9},
                    {r:8, c:9}, {r:7, c:9}, {r:6, c:9}, {r:5, c:9}, {r:4, c:9}, {r:3, c:9}, {r:2, c:9},
                    {r:2, c:8}, {r:2, c:7}, {r:2, c:6}, {r:2, c:5}, {r:2, c:4}, {r:2, c:3}, {r:2, c:2},
                    {r:3, c:2}, {r:4, c:2}, {r:5, c:2}, {r:6, c:2}, {r:7, c:2},
                    {r:7, c:3}, {r:7, c:4}, {r:7, c:5}, {r:7, c:6}, {r:7, c:7},
