<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Pembelajaran: Labirin Harta Karun</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;800;900&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #1e293b;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(74, 222, 128, 0.1), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(56, 189, 248, 0.1), transparent 25%);
            margin: 0;
            overflow-x: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        h1, h2, h3, .font-heading {
            font-family: 'Fredoka One', cursive;
        }

        /* Layout Utama */
        .game-container {
            width: 100%;
            max-width: 1200px;
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 20px;
            padding: 20px;
        }

        @media (max-width: 1100px) {
            .game-container {
                grid-template-columns: 1fr;
            }
            .main-column { order: 1; }
            .sidebar-right { order: 2; }
        }

        /* Responsivitas untuk Tablet kecil dan Smartphone (Mobile) */
        @media (max-width: 768px) {
            .game-container { padding: 10px; gap: 15px; }
            .panel { padding: 15px; border-width: 4px; border-radius: 20px;}
            .panel-header { font-size: 1.4rem; margin-bottom: 10px; }
            
            /* Papan permainan */
            .board-wrapper { padding: 8px; border-width: 6px; border-radius: 20px; }
            .board { gap: 2px; padding: 2px; border-radius: 10px; }
            
            /* Modal / Pop-up Kuis */
            .modal-content { padding: 20px; width: 95%; border-width: 5px; border-radius: 20px; }
            .modal-title { font-size: 1.8rem; }
            .modal-text { font-size: 1rem; margin-bottom: 15px; }
            .quiz-btn { font-size: 0.95rem; padding: 10px; border-width: 2px; }
            
            /* Elemen UI Lainnya */
            .btn-action { font-size: 1rem; padding: 8px 16px; border-width: 3px; box-shadow: 0 4px 0 #b45309; }
            .dice { width: 60px; height: 60px; font-size: 2rem; margin-bottom: 10px; border-width: 3px; }
            .font-heading.text-4xl { font-size: 2rem; line-height: 1.2; }
        }

        /* Papan Permainan Utama (Perbaikan Grid) */
        .board-wrapper {
            background-color: #0f172a;
            padding: 15px;
            border: 8px solid #334155;
            border-radius: 25px;
            box-shadow: 0 10px 0 #0f172a;
            width: 100%;
            margin: 0 auto;
        }
        
        .board {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            grid-template-rows: repeat(12, 1fr);
            gap: 3px;
            background-color: #14532d;
            padding: 5px;
            border-radius: 15px;
            aspect-ratio: 1 / 1;
            width: 100%;
        }

        /* Sel Grid */
        .cell {
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: clamp(10px, 2vw, 1.5rem);
            position: relative;
            transition: all 0.3s;
            aspect-ratio: 1 / 1;
        }

        /* Pola Rumput Papan (Land) */
        .cell.land { background-color: #4ade80; }
        .cell.land-alt { background-color: #22c55e; }

        /* Lingkungan Alam */
        .cell.river {
            background-color: #38bdf8;
            background-image: linear-gradient(45deg, rgba(255,255,255,0.15) 25%, transparent 25%, transparent 50%, rgba(255,255,255,0.15) 50%, rgba(255,255,255,0.15) 75%, transparent 75%, transparent);
            background-size: 20px 20px;
            animation: flow 2s linear infinite;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.2);
        }
        
        @keyframes flow {
            0% { background-position: 0 0; }
            100% { background-position: 20px 20px; }
        }

        .cell.scenery {
            font-size: clamp(12px, 2.5vw, 2rem);
            filter: drop-shadow(2px 3px 1px rgba(0,0,0,0.2));
            z-index: 1;
        }

        /* Jalur Labirin */
        .cell.path {
            background: linear-gradient(135deg, #FCEFB4, #F3D076);
            border: 2px solid #C48044;
            box-shadow: 0 4px 0 #C48044;
            z-index: 2;
        }
        
        .cell.path.bridge {
            background: linear-gradient(90deg, #8B4513, #A0522D, #8B4513);
            border: 2px solid #5C3A21;
            box-shadow: 0 4px 0 #3e2413;
        }
        
        .cell.start { background: #4ade80 !important; border-color: #166534 !important; box-shadow: 0 4px 0 #166534 !important;}
        .cell.finish { background: #f87171 !important; border-color: #991b1b !important; box-shadow: 0 4px 0 #991b1b !important;}

        /* Zona Aman (Safe Zone) */
        .cell.path.safe {
            background: linear-gradient(135deg, #cbd5e1, #94a3b8) !important;
            border-color: #475569 !important;
            box-shadow: 0 4px 0 #475569 !important;
        }

        .cell-content {
            position: absolute;
            font-size: clamp(12px, 2.5vw, 1.8rem);
            filter: drop-shadow(2px 2px 0px rgba(0,0,0,0.3));
            animation: floatItem 2s infinite ease-in-out;
        }

        @keyframes floatItem {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        /* Pion Pemain */
        .pawn {
            position: absolute;
            border-radius: 50%;
            border: 2px solid white;
            box-shadow: 0 3px 6px rgba(0,0,0,0.4);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            transition: top 0.4s ease, left 0.4s ease, width 0.3s, height 0.3s, font-size 0.3s;
        }

        /* Animasi Lempar Dadu */
        .dice-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 20px;
        }
        .dice {
            width: 80px;
            height: 80px;
            background: white;
            border: 4px solid #1e293b;
            border-radius: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 3rem;
            font-weight: bold;
            color: #1e293b;
            box-shadow: inset 0 -5px 0 #cbd5e1, 0 6px 0 #0f172a;
            margin-bottom: 15px;
            transition: transform 0.1s;
        }
        .dice.rolling {
            animation: shake 0.4s infinite;
        }
        @keyframes shake {
            0% { transform: translate(1px, 1px) rotate(0deg); }
            10% { transform: translate(-1px, -2px) rotate(-10deg); }
            20% { transform: translate(-3px, 0px) rotate(10deg); }
            30% { transform: translate(3px, 2px) rotate(0deg); }
            40% { transform: translate(1px, -1px) rotate(10deg); }
            50% { transform: translate(-1px, 2px) rotate(-10deg); }
            60% { transform: translate(-3px, 1px) rotate(0deg); }
            70% { transform: translate(3px, 1px) rotate(-10deg); }
            80% { transform: translate(-1px, -1px) rotate(10deg); }
            90% { transform: translate(1px, 2px) rotate(0deg); }
            100% { transform: translate(1px, -2px) rotate(-10deg); }
        }

        .btn-action {
            font-family: 'Fredoka One', cursive;
            background: #fde047;
            color: #b45309;
            border: 4px solid #b45309;
            padding: 10px 20px;
            font-size: 1.2rem;
            border-radius: 15px;
            cursor: pointer;
            box-shadow: 0 6px 0 #b45309;
            transition: all 0.1s;
            text-transform: uppercase;
        }
        .btn-action:active {
            transform: translateY(6px);
            box-shadow: 0 0 0 #b45309;
        }
        .btn-action:disabled {
            background: #cbd5e1;
            border-color: #64748b;
            color: #64748b;
            box-shadow: 0 6px 0 #64748b;
            cursor: not-allowed;
            transform: none;
        }

        /* Tabel Leaderboard */
        .score-table { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
        .score-table th { text-align: left; padding: 5px 10px; color: #64748b; font-size: 0.9rem; text-transform: uppercase; }
        .score-row { background: #f1f5f9; border-radius: 10px; transition: transform 0.2s; }
        .score-row.active { background: #bbf7d0; border: 2px solid #22c55e; transform: scale(1.05); }
        .score-row td { padding: 10px; font-weight: 800; color: #334155; }
        .score-row td:first-child { border-radius: 10px 0 0 10px; }
        .score-row td:last-child { border-radius: 0 10px 10px 0; text-align: right; font-size: 1.2rem; color: #e11d48;}
        
        .life-badge {
            display: inline-block;
            background: #fee2e2;
            color: #ef4444;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 0.8rem;
            margin-left: 5px;
        }

        /* Modal Overlay */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(5px);
            display: flex; justify-content: center; align-items: center;
            z-index: 100;
            opacity: 0; visibility: hidden;
            transition: all 0.3s;
        }
        .modal-overlay.show { opacity: 1; visibility: visible; }
        
        .modal-content {
            background: #ffffff;
            border: 8px solid #1e293b;
            border-radius: 30px;
            padding: 30px;
            width: 90%;
            max-width: 500px;
            text-align: center;
            box-shadow: 10px 10px 0px #0f172a;
            transform: scale(0.8);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-overlay.show .modal-content { transform: scale(1); }

        .modal-icon { font-size: 5rem; margin-bottom: 10px; animation: bounce 1s infinite; }
        .modal-title { font-size: 2.5rem; color: #e11d48; text-shadow: 2px 2px 0px #fde047; margin-bottom: 10px; font-family: 'Fredoka One';}
        .modal-text { font-size: 1.2rem; color: #334155; font-weight: 800; margin-bottom: 20px; }

        /* Kuis Options */
        .quiz-options {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            margin-bottom: 20px;
        }
        .quiz-btn {
            background: #f8fafc;
            border: 3px solid #cbd5e1;
            padding: 12px;
            border-radius: 15px;
            font-weight: 800;
            font-size: 1.1rem;
            color: #334155;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
        }
        .quiz-btn:hover { background: #e2e8f0; border-color: #94a3b8; }
        .quiz-btn.correct { background: #bbf7d0; border-color: #22c55e; color: #166534; }
        .quiz-btn.wrong { background: #fecaca; border-color: #ef4444; color: #991b1b; }

        /* Utility untuk menyembunyikan layar menu/game */
        .hide-screen { display: none !important; }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

    </style>
</head>
<body>

    <!-- Tombol Kembali Fixed di Pojok Kiri Atas -->
    <button id="btn-back" onclick="handleBackClick()" class="fixed top-4 left-4 z-[9999] bg-yellow-400 border-2 md:border-4 border-slate-800 text-slate-800 p-2 rounded-xl hover:bg-yellow-300 active:translate-y-1 active:shadow-none shadow-[0_3px_0_#0f172a] transition-all flex items-center justify-center w-10 h-10 md:w-12 md:h-12 font-heading hide-screen" style="position: fixed !important;" title="Kembali ke Menu Utama">
        <span class="text-sm md:text-lg">⬅️</span>
    </button>

    <!-- Tombol Suara Musik Fixed -->
    <button id="btn-sound" onclick="toggleSound()" class="fixed top-4 right-20 z-[9999] bg-yellow-400 border-4 border-slate-800 text-slate-800 p-3 rounded-2xl hover:bg-yellow-300 active:translate-y-1 active:shadow-none shadow-[0_4px_0_#0f172a] transition-all flex items-center justify-center w-12 h-12 md:w-14 md:h-14 font-heading" style="position: fixed !important; right: 80px !important;" title="Matikan/Nyalakan Suara">
        <span id="sound-icon" class="text-xl md:text-2xl">🔊</span>
    </button>

    <!-- Tombol Fullscreen Fixed -->
    <button id="btn-fullscreen" onclick="toggleFullscreen()" class="fixed top-4 right-4 z-[9999] bg-yellow-400 border-4 border-slate-800 text-slate-800 p-3 rounded-2xl hover:bg-yellow-300 active:translate-y-1 active:shadow-none shadow-[0_4px_0_#0f172a] transition-all flex items-center justify-center w-12 h-12 md:w-14 md:h-14 font-heading" style="position: fixed !important;" title="Layar Penuh">
        <span id="fullscreen-icon" class="text-xl md:text-2xl">🖥️</span>
    </button>

    <!-- Layar Utama / Menu -->
    <div id="screen-menu" class="w-full max-w-md bg-white border-8 border-slate-800 rounded-[30px] shadow-[10px_10px_0_#0f172a] p-8 text-center mx-4 z-50">
        <div class="text-6xl mb-4">🗺️</div>
        <h1 class="font-heading text-4xl text-yellow-400 drop-shadow-[2px_2px_0_rgba(225,29,72,1)] mb-6" style="-webkit-text-stroke: 2px #be123c;">LABIRIN HARTA KARUN</h1>
        <p class="font-bold text-slate-500 mb-8 bg-slate-100 p-2 rounded-xl border-2 border-slate-200">Pilih Mode Permainan:</p>
        
        <div class="flex flex-col gap-4">
            <button onclick="selectMode(1)" class="btn-action w-full !text-2xl !py-4 flex justify-center items-center gap-3"><span class="text-3xl">👤</span> Mode Solo</button>
            <button onclick="selectMode(2)" class="btn-action w-full !text-2xl !py-4 flex justify-center items-center gap-3"><span class="text-3xl">👥</span> Mode Duo</button>
            <button onclick="selectMode(4)" class="btn-action w-full !text-2xl !py-4 flex justify-center items-center gap-3"><span class="text-3xl">🧑‍🤝‍🧑</span> Mode Squad</button>
        </div>
    </div>

    <!-- Layar Setup Pemain -->
    <div id="screen-setup" class="hide-screen w-full max-w-lg bg-white border-8 border-slate-800 rounded-[30px] shadow-[10px_10px_0_#0f172a] p-8 text-center mx-4 z-50 max-h-[95vh] overflow-y-auto">
        <h2 class="font-heading text-3xl text-slate-700 mb-2">Persiapan Pemain</h2>
        <p class="font-bold text-slate-500 mb-6">Masukkan nama jagoanmu!</p>
        
        <div id="player-inputs" class="flex flex-col gap-4 mb-6">
            <!-- Dinamis via JS -->
        </div>

        <!-- Aturan Main -->
        <div class="text-left bg-yellow-100 p-5 rounded-2xl border-4 border-yellow-400 mb-6 shadow-sm">
            <h3 class="font-heading text-xl text-yellow-700 mb-3 border-b-2 border-yellow-300 pb-2">📜 Aturan Main</h3>
            <ol class="list-decimal pl-5 text-sm font-bold text-slate-700 space-y-2">
                <li>Klik <strong>Lempar Dadu</strong> untuk melangkah.</li>
                <li>Jika berhenti di 💰, jawab pertanyaan Pancasila.</li>
                <li>Jawaban benar = +10 Poin.</li>
                <li>Jawaban salah = berkurang (kecuali punya ❤️ Nyawa).</li>
                <li>Pemain pertama yang mencapai <strong>FINISH</strong> mengakhiri level/game.</li>
                <li>Waspadai ubin berbahaya seperti ♨️ (-5) dan ☣️!</li>
                <li>Ubin abu-abu 🛡️ adalah <strong>Zona Aman</strong> (bebas dari tabrakan pemain lain).</li>
                <li>Pemenang adalah yang memiliki <strong>Poin Tertinggi</strong>!</li>
            </ol>
        </div>
        
        <div class="flex justify-center gap-4 flex-wrap">
            <button onclick="handleBackClick()" class="btn-action !py-2 !px-6 !text-base !border-2 !shadow-[0_4px_0_#64748b] !bg-slate-300 !border-slate-500 !text-slate-700 w-auto max-w-xs transition-all">Kembali</button>
            <button onclick="startGame()" class="btn-action !py-2 !px-6 !text-base !border-2 !shadow-[0_4px_0_#15803d] !bg-green-400 !border-green-700 !text-green-900 w-auto max-w-xs transition-all">Mulai Petualangan!</button>
        </div>
    </div>

    <!-- Bungkus Game UI -->
    <div id="screen-game" class="game-container hide-screen">
        
        <!-- Kolom Utama: Judul, Papan, dan Kontrol Bawah -->
        <div class="main-column flex flex-col gap-5">
            <!-- Judul Game & Level -->
            <div class="panel text-center flex flex-col items-center justify-center py-4">
                <h1 class="font-heading text-4xl md:text-5xl text-yellow-400 drop-shadow-[2px_2px_0_rgba(225,29,72,1)]" style="-webkit-text-stroke: 2px #be123c;">LABIRIN HARTA KARUN</h1>
                <div class="flex gap-2 justify-center mt-2 flex-wrap">
                    <span class="font-bold text-slate-600 text-sm bg-slate-100 py-1 px-4 rounded-full border-2 border-slate-300 inline-block">Pendidikan Pancasila</span>
                    <span id="level-display-badge" class="font-bold text-rose-600 text-sm bg-rose-100 py-1 px-4 rounded-full border-2 border-rose-300 inline-block">Level 1</span>
                </div>
            </div>

            <!-- Tengah: Papan Labirin -->
            <div class="board-wrapper">
                <div id="game-board" class="board">
                    <!-- Grid dibuat via JS -->
                </div>
            </div>

            <!-- Bawah Papan: Dadu & Legenda -->
            <div class="bottom-controls flex flex-col md:flex-row gap-5">
                <!-- Giliran & Dadu -->
                <div class="panel flex-1 flex flex-col justify-center items-center">
                    <h2 class="panel-header">🎲 Giliran</h2>
                    <div class="text-center mb-2">
                        <span id="turn-indicator" class="inline-block px-4 py-2 rounded-xl text-white font-bold text-xl shadow-md border-2 border-slate-800">
                            Pemain 1
                        </span>
                    </div>
                    <div class="dice-container w-full max-w-[200px] mt-2">
                        <div id="dice" class="dice">1</div>
                        <button id="btn-roll" class="btn-action w-full mt-2">Lempar Dadu</button>
                    </div>
                </div>

                <!-- Legenda -->
                <div class="panel flex-1">
                    <h2 class="panel-header">🔑 Legenda</h2>
                    <ul class="text-sm font-bold text-slate-600 space-y-2 grid grid-cols-1 sm:grid-cols-2 gap-x-3 gap-y-2 text-left m-0 p-0">
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">💰</span> Jawab (+10)</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">⭐</span> Bonus (+15)</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">⚠️</span> Jebakan Mundur</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">🔄</span> Jalan Pintas</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">♨️</span> Air Panas (-5)</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">❤️</span> Nyawa (+1)</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">☣️</span> Bahaya (Mundur START)</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">🛡️</span> Zona Aman (Anti Tabrak)</li>
                        <li class="flex items-center gap-2 bg-slate-50 p-2 rounded-lg border"><span class="text-xl">⚡</span> Petir (Poin Reset 0)</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Panel Kanan: Leaderboard -->
        <div class="sidebar-right flex flex-col gap-5">
            <div class="panel h-full">
                <h2 class="panel-header">🏆 Papan Skor</h2>
                <table class="score-table">
                    <thead>
                        <tr>
                            <th>Pemain</th>
                            <th class="text-right">Poin</th>
                        </tr>
                    </thead>
                    <tbody id="leaderboard-body">
                        <!-- Baris skor via JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Kuis -->
    <div id="quiz-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-icon">💰</div>
            <h2 class="modal-title">Harta Karun!</h2>
            <p id="quiz-question" class="modal-text">Pertanyaan akan muncul di sini...</p>
            <div id="quiz-options" class="quiz-options">
                <!-- Tombol via JS -->
            </div>
            <p id="quiz-feedback" class="font-bold text-lg hidden mt-2"></p>
        </div>
    </div>

    <!-- Modal Informasi -->
    <div id="info-modal" class="modal-overlay">
        <div class="modal-content">
            <div id="info-icon" class="modal-icon">⚠️</div>
            <h2 id="info-title" class="modal-title">Perhatian!</h2>
            <p id="info-text" class="modal-text">Pesan informasi di sini.</p>
            <button id="btn-info-close" class="btn-action mt-4">Lanjut</button>
        </div>
    </div>

    <!-- Modal Pemenang -->
    <div id="winner-modal" class="modal-overlay">
        <div class="modal-content !max-w-2xl">
            <div class="modal-icon">🎉🏆🎉</div>
            <h2 class="modal-title !text-5xl">SELESAI!</h2>
            <p class="modal-text text-xl" id="winner-level-msg">Seseorang telah mencapai garis Finish.</p>
            <div class="bg-slate-100 p-5 rounded-2xl border-4 border-slate-300 mb-5">
                <h3 class="font-heading text-2xl text-slate-700 mb-3">Hasil Akhir:</h3>
                <div id="final-standings" class="flex flex-col gap-2"></div>
            </div>
            <div class="flex justify-center gap-4 flex-wrap" id="winner-actions">
                <!-- Tombol aksi dinamis via JS -->
            </div>
        </div>
    </div>

    <!-- Modal Konfirmasi Keluar Game -->
    <div id="confirm-exit-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-icon">🚪</div>
            <h2 class="modal-title">Keluar Game?</h2>
            <p class="modal-text">Apakah kamu yakin ingin kembali ke menu utama? Semua skor dan kemajuan bermain saat ini akan terhapus!</p>
            <div class="flex gap-3 justify-center">
                <button onclick="closeExitModal()" class="btn-action !bg-slate-300 !border-slate-500 !text-slate-700 !shadow-[0_6px_0_#64748b] w-1/2">Batal</button>
