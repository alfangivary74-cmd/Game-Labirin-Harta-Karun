            setupContainer.innerHTML = '';
            
            for(let i = 0; i < numPlayers; i++) {
                // Acak buff secara acak untuk masing-masing pemain baru
                const randomBuff = BUFFS[Math.floor(Math.random() * BUFFS.length)];

                setupContainer.innerHTML += `
                    <div class="text-left bg-slate-50 p-3 rounded-xl border-2 border-slate-200">
                        <label class="font-bold text-slate-600 block mb-2 text-sm flex items-center gap-2">
                            <span class="text-xl">${playerConfigs[i].emoji}</span> Nama Pemain ${i+1}
                        </label>
                        <div class="flex gap-3 items-center">
                            <!-- Kolom Input Nama -->
                            <input type="text" id="pname-${i}" class="flex-1 p-3 border-4 border-slate-300 rounded-xl font-bold text-slate-700 outline-none focus:border-blue-500 transition-colors" placeholder="Ketik nama..." value="Pemain ${i+1}" maxlength="15">
                            
                            <!-- Wadah Ikon Buff Interaktif (Samping Kanan Nama Pemain) -->
                            <div class="flex flex-col items-center justify-center bg-amber-50 border-4 border-amber-300 w-14 h-14 rounded-xl cursor-pointer hover:scale-105 active:scale-95 transition-all shadow-sm" 
                                 onclick="showInfoModal('${randomBuff.icon} ${randomBuff.name}', '${randomBuff.desc}')" 
                                 title="${randomBuff.name}: Klik untuk detail!">
                                 <span class="text-2xl animate-pulse">${randomBuff.icon}</span>
                                 <span class="text-[8px] font-heading text-amber-700 leading-none mt-0.5">BUFF</span>
                            </div>
                            
                            <!-- Data Rahasia Penyimpanan ID Buff -->
                            <input type="hidden" id="pbuff-${i}" value="${randomBuff.id}">
                        </div>
                    </div>
                `;
            }
            
            document.getElementById('screen-setup').classList.remove('hide-screen');
        }

        function startGame() {
            players = []; 
            currentLevel = 1; // Selalu mulai dari Level 1
            
            for(let i = 0; i < selectedMode; i++) {
                const nameInput = document.getElementById(`pname-${i}`).value.trim() || `Pemain ${i+1}`;
                const buffId = document.getElementById(`pbuff-${i}`).value;
                const assignedBuff = BUFFS.find(b => b.id === buffId);

                // Tetapkan nilai awal berdasarkan buff yang didapatkan
                let initialScore = 0;
                let initialLife = 0;

                if (assignedBuff.id === 'points') initialScore = 5;
                if (assignedBuff.id === 'life') initialLife = 1;

                players.push({
                    id: i,
                    name: nameInput,
                    color: playerConfigs[i].color,
                    emoji: playerConfigs[i].emoji,
                    position: 0,
                    score: initialScore,
                    hasLife: initialLife,
                    buff: assignedBuff,
                    hasShield: assignedBuff.id === 'shield',
                    hasSteal: assignedBuff.id === 'steal'
                });
            }
            
            document.getElementById('screen-setup').classList.add('hide-screen');
            document.getElementById('screen-game').classList.remove('hide-screen');
            document.getElementById('btn-back').classList.remove('hide-screen');
            
            currentPlayerIndex = 0;
            initBoard();
        }

        // --- LOGIKA TOMBOL KEMBALI & EXIT ---
        function handleBackClick() {
            AudioHelper.playSelect();
            const setupScreen = document.getElementById('screen-setup');
            if (setupScreen && !setupScreen.classList.contains('hide-screen')) {
                showMenu();
            } else {
                document.getElementById('confirm-exit-modal').classList.add('show');
            }
        }

        function closeExitModal() {
            AudioHelper.playSelect();
            document.getElementById('confirm-exit-modal').classList.remove('show');
        }

        function confirmExit() {
            AudioHelper.playSelect();
            document.getElementById('confirm-exit-modal').classList.remove('show');
            
            isMoving = false;
            document.getElementById('btn-roll').disabled = false;
            document.getElementById('game-board').innerHTML = '';
            
            // Bersihkan data peta
            pathData = [];
            currentLevel = 1;
            
            showMenu();
        }

        // --- INISIALISASI GAME ---
        window.onload = () => {
            showMenu();
            
            const startBgmOnInteraction = () => {
                AudioHelper.playAmbientBGM();
                document.removeEventListener('click', startBgmOnInteraction);
                document.removeEventListener('touchstart', startBgmOnInteraction);
            };
            document.addEventListener('click', startBgmOnInteraction);
            document.addEventListener('touchstart', startBgmOnInteraction);
        };

        function toggleSound() {
            const isMuted = AudioHelper.toggleMute();
            const soundIcon = document.getElementById('sound-icon');
            if (isMuted) {
                soundIcon.innerText = "🔇";
                soundIcon.parentElement.title = "Nyalakan Musik Latar";
            } else {
                soundIcon.innerText = "🔊";
                soundIcon.parentElement.title = "Matikan Musik Latar";
                AudioHelper.playSelect(); 
            }
        }

        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                const docEl = document.documentElement;
                if (docEl.requestFullscreen) {
                    docEl.requestFullscreen();
                } else if (docEl.mozRequestFullScreen) { 
                    docEl.mozRequestFullScreen();
                } else if (docEl.webkitRequestFullscreen) { 
                    docEl.webkitRequestFullscreen();
                } else if (docEl.msRequestFullscreen) { 
                    docEl.msRequestFullscreen();
                }
            } else {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                } else if (document.mozCancelFullScreen) {
                    document.mozCancelFullScreen();
                } else if (document.webkitExitFullscreen) {
                    document.webkitExitFullscreen();
                } else if (document.msExitFullscreen) {
                    document.msExitFullscreen();
                }
            }
        }

        document.addEventListener('fullscreenchange', handleFullscreenChange);
        document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
        document.addEventListener('mozfullscreenchange', handleFullscreenChange);
        document.addEventListener('MSFullscreenChange', handleFullscreenChange);

        function handleFullscreenChange() {
            const btnIcon = document.getElementById('fullscreen-icon');
            if (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement) {
                btnIcon.innerText = "❌"; 
                btnIcon.title = "Keluar Layar Penuh";
            } else {
                btnIcon.innerText = "🖥️"; 
                btnIcon.title = "Layar Penuh";
            }
            setTimeout(updateAllPawnsVisuals, 300);
        }

    </script>
</body>
</html>
