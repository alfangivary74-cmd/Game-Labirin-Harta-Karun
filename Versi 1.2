        let pathData = []; 
        let activePlayerForKGB = null;
        const sceneryElements = ['🌲', '🌳', '🏕️', '⛰️', '🪵', '🍄', '🌿'];

        function randomizePath() {
            const coords = getLevelCoords(currentLevel);
            pathData = [];
            
            // Masukkan koordinat Start pertama
            pathData.push({ r: coords[0].r, c: coords[0].c, type: 'start' });
            
            // Hitung sisa ubin yang berada di tengah-tengah
            let middleCount = coords.length - 2;
            let tileTypes = [];
            
            // Penjatahan proporsional sesuai total panjang jalur tingkat tertentu
            let numTreasures = Math.floor(middleCount * 0.22);
            let numSafeZones = Math.floor(middleCount * 0.08);
            let numTraps = Math.floor(middleCount * 0.08);
            let numBonus = Math.floor(middleCount * 0.08);
            let numShortcuts = Math.floor(middleCount * 0.06);
            let numLifes = Math.floor(middleCount * 0.04);
            let numPenalties = Math.floor(middleCount * 0.08);
            let numRestarts = Math.floor(middleCount * 0.04);
            let numLightnings = 2; // TEPAT 2 PETAK PETIR
            
            for(let i=0; i<numTreasures; i++) tileTypes.push({type: 'treasure'});
            for(let i=0; i<numSafeZones; i++) tileTypes.push({type: 'safe'});
            for(let i=0; i<numTraps; i++) tileTypes.push({type: 'trap', val: -3});
            for(let i=0; i<numBonus; i++) tileTypes.push({type: 'bonus', val: 15});
            for(let i=0; i<numShortcuts; i++) tileTypes.push({type: 'shortcut', val: 4});
            for(let i=0; i<numLifes; i++) tileTypes.push({type: 'life'});
            for(let i=0; i<numPenalties; i++) tileTypes.push({type: 'penalty', val: -5});
            for(let i=0; i<numRestarts; i++) tileTypes.push({type: 'restart'});
            for(let i=0; i<numLightnings; i++) tileTypes.push({type: 'lightning'});
            
            // Penuhi sisanya dengan Normal Grass
            while(tileTypes.length < middleCount) {
                tileTypes.push({type: 'normal'});
            }
            
            // Kocok urutan tipe ubin menggunakan algoritma Fisher-Yates Shuffle
            for (let i = tileTypes.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [tileTypes[i], tileTypes[j]] = [tileTypes[j], tileTypes[i]];
            }
            
            // Kombinasikan koordinat level dengan hasil kocokan
            for(let i = 1; i <= middleCount; i++) {
                const coord = coords[i];
                const tile = tileTypes[i-1];
                pathData.push({
                    r: coord.r,
                    c: coord.c,
                    type: tile.type,
                    val: tile.val || 0
                });
            }
            
            // Masukkan koordinat Finish terakhir
            pathData.push({ r: coords[coords.length - 1].r, c: coords[coords.length - 1].c, type: 'finish' });
        }

        function initBoard() {
            const board = document.getElementById('game-board');
            board.innerHTML = ''; // Hapus sisa papan sebelumnya
            
            // Pastikan peta sudah teracak jika belum pernah dibuat
            if (pathData.length === 0) {
                randomizePath();
            }
            
            // Perbarui indikator Level di atas layar
            document.getElementById('level-display-badge').innerText = `Level ${currentLevel}`;

            let gridLayout = [];
            for(let i=0; i<12; i++) {
                gridLayout[i] = new Array(12).fill(null);
            }

            pathData.forEach((pd, index) => {
                gridLayout[pd.r][pd.c] = { isPath: true, index: index, data: pd };
            });

            for(let r = 0; r < 12; r++) {
                for(let c = 0; c < 12; c++) {
                    const cell = document.createElement('div');
                    cell.className = 'cell';
                    if (r === 5 || r === 6) cell.classList.add('river');

                    const cellData = gridLayout[r][c];
                    
                    if (cellData && cellData.isPath) {
                        cell.classList.add('path');
                        if (r === 5 || r === 6) cell.classList.add('bridge');
                        if (cellData.data.type === 'safe') cell.classList.add('safe');
                        
                        cell.id = `cell-${cellData.index}`;
                        
                        let icon = '';
                        if(cellData.data.type === 'start') { cell.classList.add('start'); icon = '🏁'; }
                        else if(cellData.data.type === 'finish') { cell.classList.add('finish'); icon = '🏆'; }
                        else if(cellData.data.type === 'treasure') icon = '💰';
                        else if(cellData.data.type === 'trap') icon = '⚠️';
                        else if(cellData.data.type === 'bonus') icon = '⭐';
                        else if(cellData.data.type === 'shortcut') icon = '🔄';
                        else if(cellData.data.type === 'life') icon = '❤️';
                        else if(cellData.data.type === 'penalty') icon = '♨️';
                        else if(cellData.data.type === 'restart') icon = '☣️';
                        else if(cellData.data.type === 'safe') icon = '🛡️';
                        else if(cellData.data.type === 'lightning') icon = '⚡';

                        if(icon) {
                            const span = document.createElement('span');
                            span.className = 'cell-content';
                            span.innerText = icon;
                            cell.appendChild(span);
                        }
                    } else {
                        cell.classList.add('land');
                        if ((r + c) % 2 === 0) cell.classList.add('land-alt');

                        if (Math.random() > 0.4 && !(r === 5 || r === 6)) {
                            cell.classList.add('scenery');
                            cell.innerText = sceneryElements[Math.floor(Math.random() * sceneryElements.length)];
                        }
                    }
                    board.appendChild(cell);
                }
            }

            // Letakkan pion pemain
            players.forEach(p => {
                const pawn = document.createElement('div');
                pawn.className = 'pawn';
                pawn.id = `pawn-${p.id}`;
                pawn.style.backgroundColor = p.color;
                pawn.innerText = p.emoji;
                board.appendChild(pawn);
            });

            updateAllPawnsVisuals();
            updateLeaderboard();
            updateTurnUI();
        }

        function getCellPosition(index) {
            const cell = document.getElementById(`cell-${index}`);
            if(!cell) return { top: 0, left: 0, width: 0, height: 0 };
            return {
                top: cell.offsetTop,
                left: cell.offsetLeft,
                width: cell.offsetWidth,
                height: cell.offsetHeight
            };
        }

        function updateAllPawnsVisuals() {
            let positions = {};
            players.forEach(p => {
                if(!positions[p.position]) positions[p.position] = [];
                positions[p.position].push(p.id);
            });

            players.forEach(p => {
                const pawn = document.getElementById(`pawn-${p.id}`);
                if (!pawn) return;
                const rect = getCellPosition(p.position);
                
                const pWidth = Math.min(35, rect.width * 0.75); 
                pawn.style.width = `${pWidth}px`;
                pawn.style.height = `${pWidth}px`;
                pawn.style.fontSize = `${pWidth * 0.5}px`;
                
                const siblings = positions[p.position];
                const myIndex = siblings.indexOf(p.id);
                
                let offsetX = 0, offsetY = 0;
                if(siblings.length > 1) {
                    const scale = pWidth / 35;
                    const offsetMap = [
                        {x: -10 * scale, y: -10 * scale}, 
                        {x: 10 * scale, y: -10 * scale}, 
                        {x: -10 * scale, y: 10 * scale}, 
                        {x: 10 * scale, y: 10 * scale},
                        {x: 0, y: 0}, 
                        {x: 0, y: -15 * scale}
                    ];
                    offsetX = offsetMap[myIndex]?.x || 0;
                    offsetY = offsetMap[myIndex]?.y || 0;
                }

                pawn.style.top = `${rect.top + (rect.height / 2) - (pWidth / 2) + offsetY}px`;
                pawn.style.left = `${rect.left + (rect.width / 2) - (pWidth / 2) + offsetX}px`;
            });
        }

        window.addEventListener('resize', () => {
            setTimeout(updateAllPawnsVisuals, 100);
        });

        window.addEventListener('orientationchange', () => {
            setTimeout(updateAllPawnsVisuals, 300);
        });

        function updateLeaderboard() {
            const tbody = document.getElementById('leaderboard-body');
            tbody.innerHTML = '';
            
            players.forEach(p => {
                const tr = document.createElement('tr');
                tr.className = `score-row ${p.id === currentPlayerIndex ? 'active' : ''}`;
                
                let lifeHtml = p.hasLife > 0 ? `<span class="life-badge">❤️ x${p.hasLife}</span>` : '';

                // Tampilkan indikator status buff di papan skor
                let buffHtml = '';
                if (p.buff) {
                    let buffActive = true;
                    if (p.buff.id === 'shield' && !p.hasShield) buffActive = false;
                    if (p.buff.id === 'steal' && !p.hasSteal) buffActive = false;
                    
                    buffHtml = `
                        <span class="inline-block ml-1 bg-amber-100 border border-amber-300 rounded-full px-1.5 py-0.5 text-xs cursor-help ${buffActive ? 'opacity-100' : 'opacity-30 line-through'}" 
                              title="${p.buff.name}: ${p.buff.desc}" 
                              onclick="showInfoModal('${p.buff.icon} ${p.buff.name}', '${p.buff.desc}')">
                            ${p.buff.icon}
                        </span>
                    `;
                }

                tr.innerHTML = `
                    <td>
                        <div class="flex items-center gap-2">
                            <div class="w-6 h-6 rounded-full border-2 border-slate-700 flex justify-center items-center text-xs" style="background:${p.color}">${p.emoji}</div>
                            ${p.name} ${lifeHtml} ${buffHtml}
                        </div>
                    </td>
                    <td>${p.score}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function updateTurnUI() {
            if(players.length === 0) return;
            const p = players[currentPlayerIndex];
            const indicator = document.getElementById('turn-indicator');
            indicator.innerText = `Giliran: ${p.name}`;
            indicator.style.backgroundColor = p.color;
            updateLeaderboard();
        }

        const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

        document.getElementById('btn-roll').addEventListener('click', async () => {
            if (isMoving) return;
            isMoving = true;
            
            const btn = document.getElementById('btn-roll');
            const dice = document.getElementById('dice');
            btn.disabled = true;
            
            dice.classList.add('rolling');
            let finalRoll = 1;
            for(let i=0; i<15; i++) {
                finalRoll = Math.floor(Math.random() * 6) + 1;
                dice.innerText = finalRoll;
                AudioHelper.playDiceRollClick(); 
                await sleep(50);
            }
            dice.classList.remove('rolling');
            AudioHelper.playDiceLanding(); 
            
            await sleep(300);
            await moveActivePlayer(finalRoll);
        });

        async function moveActivePlayer(steps) {
            const p = players[currentPlayerIndex];
            p.stoleThisTurn = null; // Reset status pencurian giliran ini
            
            for(let i = 0; i < steps; i++) {
                if(p.position < pathData.length - 1) {
                    p.position++;
                    updateAllPawnsVisuals();
                    AudioHelper.playStep(); 
                    
                    // Cek Buff Pencuri Poin (Steal) saat melewati lawan tengah jalan
                    if (p.buff && p.buff.id === 'steal' && p.hasSteal) {
                        let opponentsOnCell = players.filter(opp => opp.id !== p.id && opp.position === p.position);
                        if (opponentsOnCell.length > 0) {
                            let target = opponentsOnCell[0];
                            p.hasSteal = false; // Gunakan buff pencurian
                            target.score = Math.max(0, target.score - 5);
                            p.score += 5;
                            p.stoleThisTurn = target.name;
                            AudioHelper.playSelect();
                        }
                    }
                    
                    await sleep(300);
                }
            }
            
            if (p.stoleThisTurn) {
                // Munculkan notifikasi jika berhasil merampok poin lawan di tengah rute
                await new Promise(resolve => {
                    showInfoModal(
                        '🧲 REBUT POIN!',
                        `${p.name} mengaktifkan buff Pencuri Poin dan sukses merebut 5 Poin milik ${p.stoleThisTurn} saat melewatinya!`,
                        resolve
                    );
                });
            }
            
            await handleTileAction(p);
        }

        async function handleTileAction(player) {
            const tile = pathData[player.position];
            
            if (tile.type === 'treasure') {
                showQuizModal(player);
                return;
            } 
            else if (tile.type === 'bonus') {
                player.score += tile.val;
                showInfoModal('⭐ BONUS!', `Selamat! ${player.name} menemukan bonus dan mendapat ${tile.val} poin!`, () => nextTurn());
                return;
            }
            else if (tile.type === 'penalty') {
                // Diperbolehkan minus tanpa batasan minimum 0
                player.score += tile.val;
                showInfoModal('♨️ AIR PANAS!', `Aduh! ${player.name} terperosok ke kubangan air panas mendidih dan kehilangan ${Math.abs(tile.val)} poin!`, () => nextTurn());
                return;
            }
            else if (tile.type === 'trap') {
                showInfoModal('⚠️ JEBAKAN!', `Awas! ${player.name} terkena jebakan, mundur ${Math.abs(tile.val)} langkah.`, async () => {
                    player.position += tile.val;
                    if(player.position < 0) player.position = 0;
                    updateAllPawnsVisuals();
                    await sleep(400);
                    nextTurn(); 
                });
                return;
            }
            else if (tile.type === 'shortcut') {
                showInfoModal('🔄 JALAN PINTAS!', `Mantap! ${player.name} menemukan jalan pintas, maju ${tile.val} langkah.`, async () => {
                    player.position += tile.val;
                    // Jaga posisi agar tidak kelebihan dari garis finish
                    if(player.position >= pathData.length) player.position = pathData.length - 1;
                    updateAllPawnsVisuals();
                    await sleep(400);
                    
                    // Jika jalan pintas langsung membawanya ke garis finish
                    if(player.position === pathData.length - 1) {
                        startFinishChallenge(player);
                    } else {
                        nextTurn();
                    }
                });
                return;
            }
            else if (tile.type === 'life') {
                player.hasLife++;
                showInfoModal('❤️ NYAWA TAMBAHAN!', `${player.name} mendapatkan 1 Nyawa tambahan untuk kesempatan kuis!`, () => nextTurn());
                return;
            }
            else if (tile.type === 'restart') {
                showInfoModal('☣️ AREA RADIASI!', `Gawat sekali! ${player.name} tidak sengaja masuk ke area radiasi berbahaya dan terpaksa harus kembali dari awal (START)!`, async () => {
                    player.position = 0;
                    updateAllPawnsVisuals();
                    await sleep(400);
                    nextTurn();
                });
                return;
            }
            else if (tile.type === 'lightning') {
                if (player.buff && player.buff.id === 'shield' && player.hasShield) {
                    player.hasShield = false; // Tameng pecah/terpakai
                    showInfoModal('🛡️ TAMENG AKTIF!', `Petir dahsyat menyambar ${player.name}, tetapi Tameng Pelindungmu berhasil menyerap sengatan listrik! Poinmu aman!`, () => nextTurn());
                } else {
                    player.score = 0;
                    showInfoModal('⚡ PETIR DAHSYAT!', `Zzzaappp! ${player.name} tersambar petir dahsyat dan kehilangan seluruh poinnya menjadi 0!`, () => nextTurn());
                }
                return;
            }
            else if (tile.type === 'finish') {
                startFinishChallenge(player);
                return;
            }
            
            nextTurn();
        }

        function startFinishChallenge(player) {
            activePlayerForKGB = player;
            
            document.getElementById('kgb-player-choice').innerText = '❓';
            document.getElementById('kgb-ai-choice').innerText = '❓';
            document.getElementById('kgb-feedback').classList.add('hidden');
            
            const buttons = document.querySelectorAll('#kgb-options button');
            buttons.forEach(btn => btn.style.pointerEvents = 'auto');
            
            document.getElementById('kgb-modal').classList.add('show');
        }

        async function playKGB(playerChoice) {
            const player = activePlayerForKGB;
            const choices = ['batu', 'gunting', 'kertas'];
            const emojis = { batu: '✊', gunting: '✌️', kertas: '🖐️' };
            const aiChoice = choices[Math.floor(Math.random() * 3)];
            
            document.getElementById('kgb-player-choice').innerText = emojis[playerChoice];
            document.getElementById('kgb-ai-choice').innerText = emojis[aiChoice];
            
            const buttons = document.querySelectorAll('#kgb-options button');
            buttons.forEach(btn => btn.style.pointerEvents = 'none');
            
            const feedback = document.getElementById('kgb-feedback');
            feedback.classList.remove('hidden');
            
            let result = ''; 
            if (playerChoice === aiChoice) {
                result = 'draw';
            } else if (
                (playerChoice === 'batu' && aiChoice === 'gunting') ||
                (playerChoice === 'gunting' && aiChoice === 'kertas') ||
                (playerChoice === 'kertas' && aiChoice === 'batu')
            ) {
                result = 'win';
            } else {
                result = 'lose';
            }
            
            if (result === 'draw') {
                feedback.innerText = "⚖️ SERI! Penjaga Gerbang meniru gerakanmu. Ayo pilih lagi!";
                feedback.className = "font-bold text-lg mt-4 text-amber-500 animate-pulse";
                AudioHelper.playSelect();
                await sleep(1500);
                buttons.forEach(btn => btn.style.pointerEvents = 'auto');
            } else if (result === 'win') {
                feedback.innerText = `🎉 KAMU MENANG! ${player.name} berhasil membuka Gerbang Finish!`;
                feedback.className = "font-bold text-lg mt-4 text-green-600 animate-bounce";
                AudioHelper.playSelect();
                
                await sleep(2500);
                document.getElementById('kgb-modal').classList.remove('show');
                showWinnerModal(); 
            } else {
                feedback.innerText = `❌ KAMU KALAH! Penjaga mengusir ${player.name} mundur 4 langkah!`;
                feedback.className = "font-bold text-lg mt-4 text-red-600";
                AudioHelper.playDiceLanding();
                
                await sleep(2500);
                document.getElementById('kgb-modal').classList.remove('show');
                
                player.position = Math.max(0, player.position - 4);
                updateAllPawnsVisuals();
                await sleep(500);
                nextTurn(); 
            }
        }

        async function checkCollisions(activePlayer) {
            if (activePlayer.position === 0 || activePlayer.position === pathData.length - 1) {
                return;
            }
            
            const currentTile = pathData[activePlayer.position];
            if (currentTile && currentTile.type === 'safe') {
                return; 
            }
            
            let kickedPlayers = [];
            let shieldedPlayers = [];
            
            players.forEach(p => {
                if (p.id !== activePlayer.id && p.position === activePlayer.position) {
                    // Cek perlindungan Tameng / Shield Buff
                    if (p.buff && p.buff.id === 'shield' && p.hasShield) {
                        p.hasShield = false; // Tameng pecah/terpakai
                        shieldedPlayers.push(p.name);
                    } else {
                        p.position = 0; 
                        kickedPlayers.push(p.name);
                    }
                }
            });
            
            // Berikan notifikasi jika ada tameng yang aktif menepis tabrakan
            if (shieldedPlayers.length > 0) {
                updateAllPawnsVisuals();
                AudioHelper.playSelect();
                await new Promise(resolve => {
                    showInfoModal(
                        '🛡️ TAMENG AKTIF!',
                        `Pion ${shieldedPlayers.join(' & ')} menggunakan kekuatan Tameng Pelindung! Tabrakan dari ${activePlayer.name} berhasil ditepis dan tetap aman di tempatnya!`,
                        resolve
                    );
                });
            }
            
            if (kickedPlayers.length > 0) {
                updateAllPawnsVisuals();
                AudioHelper.playDiceLanding(); 
                
                await new Promise(resolve => {
                    showInfoModal(
                        '💥 TERTABRAK!', 
                        `${activePlayer.name} mendarat di petak yang sama! ${kickedPlayers.join(' dan ')} tertabrak kembali ke titik START!`, 
                        resolve
                    );
                });
            }
        }

        async function nextTurn() {
            await checkCollisions(players[currentPlayerIndex]);
            updateLeaderboard();
            currentPlayerIndex = (currentPlayerIndex + 1) % players.length;
            updateTurnUI();
            isMoving = false;
            document.getElementById('btn-roll').disabled = false;
        }

        let currentQuizIndex = -1;
        let activePlayerForQuiz = null;

        function showQuizModal(player) {
            activePlayerForQuiz = player;
            currentQuizIndex = Math.floor(Math.random() * pancasilaQuestions.length);
            const q = pancasilaQuestions[currentQuizIndex];
            
            document.getElementById('quiz-question').innerText = q.q;
            
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            document.getElementById('quiz-feedback').className = 'hidden'; 
            
            q.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = 'quiz-btn';
                btn.innerText = `${String.fromCharCode(65 + idx)}. ${opt}`;
                btn.onclick = () => handleQuizAnswer(idx, btn);
                optionsContainer.appendChild(btn);
            });
            
            document.getElementById('quiz-modal').classList.add('show');
        }

        async function handleQuizAnswer(selectedIndex, btnElement) {
            const q = pancasilaQuestions[currentQuizIndex];
            const p = activePlayerForQuiz;
            const buttons = document.querySelectorAll('.quiz-btn');
            
            buttons.forEach(b => b.style.pointerEvents = 'none');
            
            const feedback = document.getElementById('quiz-feedback');
            feedback.classList.remove('hidden');
            
            if(selectedIndex === q.a) {
                btnElement.classList.add('correct');
                p.score += 10;
                feedback.innerText = "✅ JAWABAN BENAR! +10 Poin";
                feedback.className = "font-bold text-xl mt-4 text-green-600";
                
                await sleep(2000);
                closeQuizModal();
            } else {
                btnElement.classList.add('wrong');
                buttons[q.a].classList.add('correct');
                
                if(p.hasLife > 0) {
                    p.hasLife--;
                    feedback.innerText = "❌ SALAH! Tapi kamu punya ❤️ Nyawa! Kesempatan kuis diulang.";
                    feedback.className = "font-bold text-xl mt-4 text-orange-500";
                    updateLeaderboard(); 
                    
                    await sleep(2000);
                    feedback.classList.add('hidden');
                    btnElement.classList.remove('wrong');
                    buttons[q.a].classList.remove('correct');
                    btnElement.style.opacity = '0.5'; 
                    
                    buttons.forEach((b, idx) => {
                        if(idx !== selectedIndex) b.style.pointerEvents = 'auto';
                    });
                } else {
                    // Jika salah dan tidak memiliki nyawa, tidak dikurangi poin
                    feedback.innerText = "❌ JAWABAN SALAH! Tetap semangat!";
                    feedback.className = "font-bold text-xl mt-4 text-red-600";
                    await sleep(2000);
                    closeQuizModal();
                }
            }
        }

        function closeQuizModal() {
            document.getElementById('quiz-modal').classList.remove('show');
            nextTurn();
        }

        let onInfoCloseCb = null;
        function showInfoModal(title, text, onClose) {
            document.getElementById('info-title').innerText = title;
            document.getElementById('info-text').innerText = text;
            
            let icon = '⚠️';
            if(title.includes('BONUS')) icon = '⭐';
            if(title.includes('PINTAS')) icon = '🔄';
            if(title.includes('NYAWA')) icon = '❤️';
            if(title.includes('AIR PANAS')) icon = '♨️';
            if(title.includes('RADIASI')) icon = '☣️';
            if(title.includes('PETIR')) icon = '⚡';
            if(title.includes('SELESAI DIACAK')) icon = '🎲';
            if(title.includes('TABRAK')) icon = '💥';
            document.getElementById('info-icon').innerText = icon;

            onInfoCloseCb = onClose;
            document.getElementById('info-modal').classList.add('show');
        }

        document.getElementById('btn-info-close').addEventListener('click', () => {
            document.getElementById('info-modal').classList.remove('show');
            if(onInfoCloseCb) onInfoCloseCb();
        });

        function showWinnerModal() {
            const standings = [...players].sort((a,b) => b.score - a.score);
            const container = document.getElementById('final-standings');
            container.innerHTML = '';
            
            standings.forEach((p, idx) => {
                let rankIcon = idx === 0 ? '🏆' : (idx === 1 ? '🥈' : (idx === 2 ? '🥉' : ''));
                container.innerHTML += `
                    <div class="flex justify-between items-center bg-white p-3 rounded-xl border border-slate-200">
                        <span class="font-bold text-lg">${rankIcon} ${p.name}</span>
                        <span class="font-heading text-xl text-slate-700">${p.score} Poin</span>
                    </div>
                `;
            });

            const levelMsg = document.getElementById('winner-level-msg');
            const actionsContainer = document.getElementById('winner-actions');
            actionsContainer.innerHTML = '';

            // Jika Mode Solo (Pemain = 1) dan belum mencapai Level 3 (level maksimal)
            if (selectedMode === 1 && currentLevel < 3) {
                levelMsg.innerText = `Luar biasa! Kamu berhasil menaklukkan tantangan di Level ${currentLevel}!`;
                
                const nextBtn = document.createElement('button');
                nextBtn.className = 'btn-action text-xl px-8 py-3 !bg-green-400 !border-green-700 !text-green-900 !shadow-[0_6px_0_#15803d]';
                nextBtn.innerText = `Lanjutkan ke Level ${currentLevel + 1}`;
                nextBtn.onclick = loadNextLevel;
                actionsContainer.appendChild(nextBtn);

                const exitBtn = document.createElement('button');
                exitBtn.className = 'btn-action text-xl px-8 py-3 !bg-slate-300 !border-slate-500 !text-slate-700 !shadow-[0_6px_0_#64748b]';
                exitBtn.innerText = 'Keluar ke Menu';
                exitBtn.onclick = () => location.reload();
                actionsContainer.appendChild(exitBtn);
            } 
            // Jika Mode Solo dan telah menamatkan Level 3
            else if (selectedMode === 1 && currentLevel === 3) {
                levelMsg.innerText = `Selamat! Kamu telah menyelesaikan seluruh Level 1, 2, dan 3! Kamu adalah Penjelajah Pancasila Sejati! 🎉🎉`;
                
                const restartBtn = document.createElement('button');
                restartBtn.className = 'btn-action text-xl px-8 py-3';
                restartBtn.innerText = 'Main Lagi dari Awal';
                restartBtn.onclick = () => location.reload();
                actionsContainer.appendChild(restartBtn);
            } 
            // Untuk Mode Multiplayer (Duo / Squad)
            else {
                levelMsg.innerText = "Seseorang telah mencapai garis Finish.";
                
                const restartBtn = document.createElement('button');
                restartBtn.className = 'btn-action text-xl px-8 py-3';
                restartBtn.innerText = 'Main Lagi';
                restartBtn.onclick = () => location.reload();
                actionsContainer.appendChild(restartBtn);
            }

            document.getElementById('winner-modal').classList.add('show');
        }

        function loadNextLevel() {
            AudioHelper.playSelect();
            document.getElementById('winner-modal').classList.remove('show');
            
            // Naik level
            currentLevel++;
            
            // Reset jatah acak untuk level baru
            randomizeTries = 3;
            
            // Jaga poin pemain lama, kembalikan posisi mereka ke START (0)
            players.forEach(p => {
                p.position = 0;
            });
            currentPlayerIndex = 0;
            
            // Bersihkan data peta lama untuk diganti dengan peta baru secara otomatis
            pathData = [];
            randomizePath(); 
            
            // Render ulang peta level baru ke layar
            initBoard();
        }

        // --- SISTEM MENU UTAMA & SETUP PEMAIN ---
        function showMenu() {
            document.getElementById('screen-menu').classList.remove('hide-screen');
            document.getElementById('screen-setup').classList.add('hide-screen');
            document.getElementById('screen-game').classList.add('hide-screen');
            document.getElementById('btn-back').classList.add('hide-screen');
        }

